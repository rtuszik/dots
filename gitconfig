[user]
    name = FIRST LAST
    email = MAIL@MAIL.COM

[init]
    defaultBranch = main

[core]
    excludesfile = $HOME/.gitignore
    editor = nvim
    pager = delta

[safe]
    directory = ${HOME_DIR}/
    directory = ${HOME_DIR}

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[push]
    autoSetupRemote = true
    followTags = true

[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true
    tool = nvimdiff

[difftool]
    prompt = true

[difftool "nvimdiff"]
    cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""

[branch]
    sort = -committerdate

[tag]
    sort = version:refname

[column]
    ui = auto

[help]
    autocorrect = prompt

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true
    hyperlinks = true
    side-by-side = true

[merge]
    conflictStyle = zdiff3

[http]
    postBuffer = 524288000
